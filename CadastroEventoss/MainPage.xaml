<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="CadastroEventoss.MainPage">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="15">

            <Label
                Text="Cadastro de Evento"
                FontSize="30"
                HorizontalOptions="Center"/>

            <Entry
                Placeholder="Nome do Evento"
                Text="{Binding NomeEvento}" />

            <DatePicker
                Date="{Binding DataInicio}" />

            <DatePicker
                Date="{Binding DataTermino}" />

            <Entry
                Placeholder="Número de Participantes"
                Keyboard="Numeric"
                Text="{Binding NumeroParticipantes}" />

            <Entry
                Placeholder="Local do Evento"
                Text="{Binding LocalEvento}" />

            <Entry
                Placeholder="Custo por Participante"
                Keyboard="Numeric"
                Text="{Binding CustoPorParticipante}" />

            <Button
                Text="Cadastrar Evento"
                Clicked="Button_Clicked"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>