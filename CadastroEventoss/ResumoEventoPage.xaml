<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="CadastroEventoss.ResumoEventoPage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="10">

            <Label
                Text="Resumo do Evento"
                FontSize="28"
                HorizontalOptions="Center"/>

            <Label Text="{Binding NomeEvento}" />

            <Label Text="{Binding LocalEvento}" />

            <Label Text="{Binding NumeroParticipantes,
                          StringFormat='Participantes: {0}'}"/>

            <Label Text="{Binding DataInicio,
                          StringFormat='Início: {0:dd/MM/yyyy}'}"/>

            <Label Text="{Binding DataTermino,
                          StringFormat='Fim: {0:dd/MM/yyyy}'}"/>

            <Label Text="{Binding DuracaoDias,
                          StringFormat='Duração: {0} dias'}"/>

            <Label Text="{Binding CustoTotal,
                          StringFormat='Custo Total: R$ {0:F2}'}"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>